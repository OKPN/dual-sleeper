  "gpu_limit_percent": 10,
  "keep_awake_window_titles": [
    "youtube:20",
    "twitch",
    "zoom:60"
  ],
  "server_mode": "off",
  "server_mode_standby_delay_seconds": 600,
  "wol_url": "https://your-wol-endpoint.workers.dev/?data=..."
